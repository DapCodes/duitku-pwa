{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/((?!assets/|manifest.json|service-worker.js|logo.png).*)" ,
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
